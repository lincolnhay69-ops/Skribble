{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Scribble",
  "version": "2.0.80",
  "identifier": "com.scribble.app",
  "build": {
    "frontendDist": "../web",
    "devUrl": "about:blank"
  },
  "app": {
    "windows": [
      {
        "title": "Scribble",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
